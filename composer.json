{
    "name": "ycookies/miniapp-manager",
    "alias": "小程序管理工具",
    "description": "提供微信，支付宝，抖音小程序的管理功能",
    "type": "library",
    "keywords": ["dcat-admin", "extension"],
    "homepage": "https://github.com/ycookies/miniapp-manager",
    "license": "MIT",
    "authors": [
        {
            "name": "杨光",
            "email": "3664839@qq.com"
        }
    ],
    "require": {
        "php": ">=7.4.0",
        "dcat-plus/laravel-admin": "~1.0|~2.0",
        "laravel/framework": "~12.0|~13.0"
    },
    "autoload": {
        "psr-4": {
            "Ycookies\\MiniappManager\\": "src/"
        }
    },
    "extra": {
        "dcat-admin": "Ycookies\\MiniappManager\\MiniappManagerServiceProvider",
        "laravel": {
            "providers": [
                "Ycookies\\MiniappManager\\MiniappManagerServiceProvider"
            ]
        }
    }
}
